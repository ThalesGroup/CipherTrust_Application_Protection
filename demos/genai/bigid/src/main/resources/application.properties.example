# udfConfig.properties
CRDPIP=192.168.159.143
METADATA=1004001
CRDPTKN=yourcrdptoken
KEYMGRHOST=yourcmhost
POLICYNAME=char-internal
DEFAULTPOLICY=char-internal
POLICYTYPE=internal
SHOWMETADATA=true
MODE=encrypt
# MODE accepts encrypt/decrypt and is normalized internally to protect/reveal.
TAGPREFIX=ENC
REVEALUSER=admin
TAG.nbr=nbr-internal
TAG.char=char-internal
TAGCODE.nbr=RU5DbmJy-
TAGCODE.char=RU5DY2hhcg==- 
PII.Person=TAG.char
PII.Address=TAG.char
PII.Email=TAG.char
PII.PhoneNumber=TAG.nbr
PII.USSocialSecurityNumber=TAG.nbr
PII.DateTime=TAG.char
PII.CreditCardNumber=TAG.nbr
PII.URL=TAG.char
bigid.baseUrl=https://your-bigid-host
bigid.systemToken=
bigid.userToken=
bigid.catalogFilter=classification="PII"
bigid.pageSize=100
bigid.classificationHints=PII,PHI,PCI
bigid.debug.dumpAssets=false
bigid.debug.dumpFile=
bigid.debug.only=false

source.mode=local
source.rootDirectory=E:/data/inbound
source.supportedExtensions=.pdf,.docx,.doc,.xlsx,.xls,.txt,.csv
output.directory=E:/data/protected
unstructured.output.writeExtractedText=false
unstructured.output.writeProtectedText=true
unstructured.output.writeFindingsReport=false

azure.storage.connectionString=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
azure.storage.targetContainer=protected
azure.storage.targetPrefix=thales-output
azure.storage.qualifiedNamePrefixes=

s3.region=us-east-1
s3.accessKey=
s3.secretKey=
s3.sessionToken=
s3.endpoint=
s3.pathStyleAccess=false
s3.targetBucket=protected-output
s3.targetPrefix=thales-output
s3.qualifiedNamePrefixes=

gcs.projectId=
gcs.credentialsPath=
gcs.targetBucket=protected-output
gcs.targetPrefix=thales-output
gcs.qualifiedNamePrefixes=

sql.enabled=false
sql.jdbcUrl=jdbc:sqlserver://host:1433;databaseName=sample
sql.user=
sql.password=
sql.sourceTables=
sql.targetSchema=dbo
sql.targetTableSuffix=_protected
sql.whereClause=
sql.writeMode=replace

azure.textAnalytics.endpoint=https://your-language-endpoint.cognitiveservices.azure.com/
azure.textAnalytics.apiKey=
azure.textAnalytics.language=en
azure.textAnalytics.confidenceThreshold=0.80

thales.keyManagerHost=
thales.registrationToken=
thales.policyName=
thales.defaultPolicy=
thales.policyType=external
thales.revealUser=
thales.showMetadata=true
